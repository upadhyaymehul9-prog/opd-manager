generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id             String         @id @default(uuid()) @db.Uuid
  patient_number Int            @unique
  name           String
  mobile         String?
  address        String?
  allergies      String?
  blood_group    String?
  abha_id        String?        @unique
  gender         String?
  emergency_contact String?
  date_of_birth  DateTime?      @db.Date
  occupation     String?
  national_id_type String?
  national_id    String?
  mobile_verify_code String?
  mobile_verified_at DateTime?  @db.Timestamptz(6)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  visits         PatientVisit[]
  appointments   Appointment[]
  consents       PatientConsent[]

  @@index([mobile])
  @@index([name])
  @@index([abha_id])
  @@map("patients")
}

model PatientRegistry {
  id          String @id @default("default")
  last_number Int    @default(0)

  @@map("patient_registry")
}

model Doctor {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  room_number    String
  specialty      String?
  bio            String?
  qualifications String?
  photo_url      String?
  consultation_fee Float?
  opd_status     String         @default("offline")
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  patient_visits PatientVisit[]
  prescriptions  Prescription[]
  appointments   Appointment[]
  users          User[]
  consultation_templates ConsultationTemplate[]

  @@map("doctors")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  username      String   @unique
  password_hash String
  role          String
  display_name  String?
  doctor_id     String?  @db.Uuid
  doctor        Doctor?  @relation(fields: [doctor_id], references: [id], onDelete: SetNull)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@map("users")
}

model PatientVisit {
  id              String    @id @default(uuid()) @db.Uuid
  patient_id      String?   @db.Uuid
  token_number    Int
  patient_name    String
  doctor_id       String    @db.Uuid
  room_number     String
  status          String    @default("registered")
  patient_type    String    @default("new")
  age             Int?
  gender          String?
  mobile          String?
  address         String?
  medico_legal    Boolean   @default(false)
  mlc_details     String?
  point_of_origin String    @default("walk_in")
  lab_referred    Boolean   @default(false)
  radio_referred  Boolean   @default(false)
  lab_eta         DateTime? @db.Timestamptz(6)
  radio_eta       DateTime? @db.Timestamptz(6)
  lab_started_at  DateTime? @db.Timestamptz(6)
  lab_ready_at    DateTime? @db.Timestamptz(6)
  radio_started_at DateTime? @db.Timestamptz(6)
  radio_ready_at  DateTime? @db.Timestamptz(6)
  registered_at   DateTime  @default(now()) @db.Timestamptz(6)
  completed_at    DateTime? @db.Timestamptz(6)
  consultation_fee        Float?
  consultation_payment_mode String?
  consultation_bill_no      String?   @unique
  consultation_paid_at      DateTime? @db.Timestamptz(6)
  chief_complaint           String?
  provisional_diagnosis     String?
  final_diagnosis           String?
  diagnosis                 String?
  examination_notes         String?
  advice                    String?
  lifestyle_advice          String?
  investigations_ordered    String?
  follow_up_instructions    String?
  referral_notes            String?
  follow_up_date            DateTime? @db.Date
  signed_at                 DateTime? @db.Timestamptz(6)
  signed_by                 String?
  signed_by_role            String?
  vitals_bp                 String?
  vitals_pulse              Int?
  vitals_temp               Float?
  vitals_weight             Float?
  vitals_spo2               Int?
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  patient         Patient?       @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  doctors         Doctor         @relation(fields: [doctor_id], references: [id], onDelete: Restrict)
  prescription    Prescription?
  pharmacy_bill   PharmacyBill?
  procedures      VisitProcedure[]
  appointment     Appointment?
  consent         PatientConsent?
  incidents       IncidentReport[]

  @@index([status])
  @@index([doctor_id])
  @@index([patient_id])
  @@index([registered_at(sort: Desc)])
  @@index([patient_name])
  @@map("patient_visits")
}

model DailyToken {
  visit_date DateTime @id @db.Date
  last_token Int      @default(0)

  @@map("daily_tokens")
}

model Medicine {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  brand              String?
  form               String?
  strength           String?
  gst_rate           Float              @default(12)
  hsn_code           String?
  is_active          Boolean            @default(true)
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  prescription_items PrescriptionItem[]
  stock_batches      StockBatch[]
  write_offs         StockWriteOff[]

  @@index([name])
  @@index([brand])
  @@map("medicines")
}

model StockBatch {
  id          String          @id @default(uuid()) @db.Uuid
  medicine_id String          @db.Uuid
  batch_no    String
  expiry_date DateTime        @db.Date
  quantity    Int
  pack_size   Int             @default(1)
  mrp         Float?
  created_at  DateTime        @default(now()) @db.Timestamptz(6)
  medicine    Medicine        @relation(fields: [medicine_id], references: [id], onDelete: Cascade)
  write_offs  StockWriteOff[]

  @@index([medicine_id])
  @@index([expiry_date])
  @@map("stock_batches")
}

model StockWriteOff {
  id          String      @id @default(uuid()) @db.Uuid
  medicine_id String      @db.Uuid
  batch_id    String?     @db.Uuid
  batch_no    String
  quantity    Int
  reason      String      @default("expired")
  notes       String?
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  medicine    Medicine    @relation(fields: [medicine_id], references: [id], onDelete: Cascade)
  batch       StockBatch? @relation(fields: [batch_id], references: [id], onDelete: SetNull)

  @@index([medicine_id])
  @@index([created_at(sort: Desc)])
  @@map("stock_write_offs")
}

model ConsultationBillCounter {
  id      String @id @default("default")
  last_no Int    @default(0)

  @@map("consultation_bill_counter")
}

model Prescription {
  id                  String             @id @default(uuid()) @db.Uuid
  patient_visit_id    String             @unique @db.Uuid
  doctor_id           String             @db.Uuid
  notes               String?
  status              String             @default("draft")
  sent_to_pharmacy_at DateTime?          @db.Timestamptz(6)
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime           @updatedAt @db.Timestamptz(6)
  patient_visit       PatientVisit       @relation(fields: [patient_visit_id], references: [id], onDelete: Cascade)
  doctor              Doctor             @relation(fields: [doctor_id], references: [id], onDelete: Restrict)
  items               PrescriptionItem[]
  pharmacy_bill       PharmacyBill?

  @@index([status])
  @@map("prescriptions")
}

model PrescriptionItem {
  id               String       @id @default(uuid()) @db.Uuid
  prescription_id  String       @db.Uuid
  medicine_id      String?      @db.Uuid
  medicine_name    String
  dose             String?
  frequency        String?
  duration_days    Int?
  quantity         Int?
  instructions     String?
  dispensed        Boolean      @default(false)
  dispensed_at     DateTime?    @db.Timestamptz(6)
  substituted_note String?
  sort_order       Int          @default(0)
  prescription     Prescription @relation(fields: [prescription_id], references: [id], onDelete: Cascade)
  medicine         Medicine?    @relation(fields: [medicine_id], references: [id], onDelete: SetNull)

  @@index([prescription_id])
  @@map("prescription_items")
}

model PharmacyBill {
  id               String             @id @default(uuid()) @db.Uuid
  bill_no          String             @unique
  patient_visit_id String             @unique @db.Uuid
  prescription_id  String             @unique @db.Uuid
  payment_mode     String
  subtotal         Float
  gst_total        Float
  grand_total      Float
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  patient_visit    PatientVisit       @relation(fields: [patient_visit_id], references: [id], onDelete: Cascade)
  prescription     Prescription       @relation(fields: [prescription_id], references: [id], onDelete: Cascade)
  items            PharmacyBillItem[]

  @@index([created_at(sort: Desc)])
  @@map("pharmacy_bills")
}

model PharmacyBillItem {
  id                   String       @id @default(uuid()) @db.Uuid
  bill_id              String       @db.Uuid
  prescription_item_id String?      @db.Uuid
  medicine_name        String
  quantity             Int
  unit_price           Float
  gst_rate             Float
  taxable_amount       Float
  gst_amount           Float
  line_total           Float
  bill                 PharmacyBill @relation(fields: [bill_id], references: [id], onDelete: Cascade)

  @@index([bill_id])
  @@map("pharmacy_bill_items")
}

model VisitProcedure {
  id               String       @id @default(uuid()) @db.Uuid
  patient_visit_id String       @db.Uuid
  procedure_type   String
  notes            String?
  fee              Float?
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  patient_visit    PatientVisit @relation(fields: [patient_visit_id], references: [id], onDelete: Cascade)

  @@index([patient_visit_id])
  @@index([procedure_type])
  @@index([created_at(sort: Desc)])
  @@map("visit_procedures")
}

model ClinicSettings {
  id                    String @id @default("default")
  slot_duration_minutes Int    @default(15)
  opd_start_hour        Int    @default(9)
  opd_end_hour          Int    @default(18)

  @@map("clinic_settings")
}

model Appointment {
  id               String        @id @default(uuid()) @db.Uuid
  doctor_id        String        @db.Uuid
  patient_id       String?       @db.Uuid
  patient_name     String
  mobile           String?
  age              Int?
  scheduled_at     DateTime      @db.Timestamptz(6)
  duration_minutes Int           @default(15)
  status           String        @default("booked")
  source           String        @default("reception")
  external_ref     String?       @unique
  notes            String?
  visit_id         String?       @unique @db.Uuid
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  doctor           Doctor        @relation(fields: [doctor_id], references: [id], onDelete: Restrict)
  patient          Patient?      @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  visit            PatientVisit? @relation(fields: [visit_id], references: [id], onDelete: SetNull)

  @@index([doctor_id, scheduled_at])
  @@index([scheduled_at(sort: Desc)])
  @@index([status])
  @@index([source])
  @@map("appointments")
}

model ConsultationTemplate {
  id                String   @id @default(uuid()) @db.Uuid
  doctor_id         String?  @db.Uuid
  title             String
  chief_complaint   String?
  diagnosis         String?
  examination_notes String?
  advice            String?
  sort_order        Int      @default(0)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  doctor            Doctor?  @relation(fields: [doctor_id], references: [id], onDelete: Cascade)

  @@index([doctor_id])
  @@map("consultation_templates")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String?  @db.Uuid
  username    String
  role        String
  action      String
  entity_type String
  entity_id   String?
  summary     String
  details     String?
  ip_address  String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@index([entity_type, entity_id])
  @@index([action])
  @@map("audit_logs")
}

model PatientConsent {
  id               String       @id @default(uuid()) @db.Uuid
  patient_visit_id String       @unique @db.Uuid
  patient_id       String?      @db.Uuid
  consent_type     String       @default("general_treatment")
  accepted         Boolean
  version          String       @default("1.0")
  recorded_by      String
  recorded_by_role String
  witness_name     String?
  consent_text     String?
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  visit            PatientVisit @relation(fields: [patient_visit_id], references: [id], onDelete: Cascade)
  patient          Patient?     @relation(fields: [patient_id], references: [id], onDelete: SetNull)

  @@index([patient_id])
  @@map("patient_consents")
}

model IncidentReport {
  id               String        @id @default(uuid()) @db.Uuid
  patient_visit_id String?       @db.Uuid
  patient_name     String
  category         String
  severity         String
  description      String
  immediate_action String?
  status           String        @default("open")
  reported_by      String
  reported_by_role String
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  closed_at        DateTime?     @db.Timestamptz(6)
  visit            PatientVisit? @relation(fields: [patient_visit_id], references: [id], onDelete: SetNull)

  @@index([created_at(sort: Desc)])
  @@index([status])
  @@map("incident_reports")
}

model PatientFeedback {
  id               String   @id @default(uuid()) @db.Uuid
  patient_visit_id String?  @db.Uuid
  patient_name     String
  mobile           String?
  q1_overall       Int
  q2_care_quality  Int
  q3_communication Int
  q4_environment   Int
  q5_registration  Int
  comments         String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@map("patient_feedback")
}
