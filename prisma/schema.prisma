generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  room_number    String
  specialty      String?
  opd_status     String         @default("offline")
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  patient_visits PatientVisit[]
  prescriptions  Prescription[]
  users          User[]

  @@map("doctors")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  username      String   @unique
  password_hash String
  role          String
  display_name  String?
  doctor_id     String?  @db.Uuid
  doctor        Doctor?  @relation(fields: [doctor_id], references: [id], onDelete: SetNull)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@map("users")
}

model PatientVisit {
  id              String    @id @default(uuid()) @db.Uuid
  token_number    Int
  patient_name    String
  doctor_id       String    @db.Uuid
  room_number     String
  status          String    @default("registered")
  patient_type    String    @default("new")
  age             Int?
  mobile          String?
  lab_referred    Boolean   @default(false)
  radio_referred  Boolean   @default(false)
  lab_eta         DateTime? @db.Timestamptz(6)
  radio_eta       DateTime? @db.Timestamptz(6)
  lab_started_at  DateTime? @db.Timestamptz(6)
  lab_ready_at    DateTime? @db.Timestamptz(6)
  radio_started_at DateTime? @db.Timestamptz(6)
  radio_ready_at  DateTime? @db.Timestamptz(6)
  registered_at   DateTime  @default(now()) @db.Timestamptz(6)
  completed_at    DateTime? @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  doctors         Doctor         @relation(fields: [doctor_id], references: [id], onDelete: Restrict)
  prescription    Prescription?

  @@index([status])
  @@index([doctor_id])
  @@index([registered_at(sort: Desc)])
  @@index([patient_name])
  @@map("patient_visits")
}

model DailyToken {
  visit_date DateTime @id @db.Date
  last_token Int      @default(0)

  @@map("daily_tokens")
}

model Medicine {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  form               String?
  strength           String?
  is_active          Boolean            @default(true)
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  prescription_items PrescriptionItem[]

  @@index([name])
  @@map("medicines")
}

model Prescription {
  id                  String             @id @default(uuid()) @db.Uuid
  patient_visit_id    String             @unique @db.Uuid
  doctor_id           String             @db.Uuid
  notes               String?
  status              String             @default("draft")
  sent_to_pharmacy_at DateTime?          @db.Timestamptz(6)
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime           @updatedAt @db.Timestamptz(6)
  patient_visit       PatientVisit       @relation(fields: [patient_visit_id], references: [id], onDelete: Cascade)
  doctor              Doctor             @relation(fields: [doctor_id], references: [id], onDelete: Restrict)
  items               PrescriptionItem[]

  @@index([status])
  @@map("prescriptions")
}

model PrescriptionItem {
  id               String       @id @default(uuid()) @db.Uuid
  prescription_id  String       @db.Uuid
  medicine_id      String?      @db.Uuid
  medicine_name    String
  dose             String?
  frequency        String?
  duration_days    Int?
  quantity         Int?
  instructions     String?
  dispensed        Boolean      @default(false)
  dispensed_at     DateTime?    @db.Timestamptz(6)
  substituted_note String?
  sort_order       Int          @default(0)
  prescription     Prescription @relation(fields: [prescription_id], references: [id], onDelete: Cascade)
  medicine         Medicine?    @relation(fields: [medicine_id], references: [id], onDelete: SetNull)

  @@index([prescription_id])
  @@map("prescription_items")
}
